  m_Name: 
  m_EditorClassIdentifier: 
  entries:
  - timestamp: 2026-01-25 08:44:05
    panelType: Vehicle Customization
    userPrompt: Rally setup
    explanation: 'Rally setup configured: Switched to AWD for better traction on
      mixed surfaces. Increased suspension travel to 0.35m (1.75x multiplier for
      rally compliance) with softer springs to absorb rough terrain. Lowered center
      of mass for stability. Increased torque to 320Nm and tuned gearbox with shorter
      ratios (4.5 first gear) and higher final drive (3.8) for quick acceleration
      out of corners. Added Slippy friction preset for loose surface grip. Increased
      downforce moderately (40) and added angular drag helper for better rotational
      stability. Limited slip ratio set to 70 (locked) for gravel traction. Maintained
      turbo and all stability aids for controllability on variable surfaces.'
    appliedJson: "{\n  \"driveType\": \"AWD\",\n  \"vehicleConfig\": {\n    \"mass\":
      1600,\n    \"centerOfMassOffset\": {\n      \"y\": -0.25\n    }\n  },\n  \"engine\":
      {\n    \"maximumTorqueAsNM\": 320,\n    \"minEngineRPM\": 700,\n    \"maxEngineRPM\":
      7500,\n    \"turboCharged\": true,\n    \"maxTurboChargePsi\": 12,\n    \"turboChargerCoEfficient\":
      1.25,\n    \"engineInertia\": 0.12\n  },\n  \"clutch\": {\n    \"engageRPM\":
      1200,\n    \"clutchInertia\": 0.12\n  },\n  \"gearbox\": {\n    \"transmissionType\":
      \"Automatic\",\n    \"gearRatios\": [4.5, 2.8, 1.8, 1.35, 1.0, 0.8],\n    \"shiftingTime\":
      0.25,\n    \"shiftThreshold\": 0.8,\n    \"shiftUpRPM\": 6000,\n    \"shiftDownRPM\":
      3000\n  },\n  \"differential\": {\n    \"type\": \"Limited\",\n    \"limitedSlipRatio\":
      70,\n    \"finalDriveRatio\": 3.8\n  },\n  \"suspension\": {\n    \"distance\":
      0.35,\n    \"spring\": 52800,\n    \"damper\": 4752\n  },\n  \"axles\": {\n   
      \"front\": {\n      \"maxSteerAngle\": 45,\n      \"maxBrakeTorque\": 5500,\n     
      \"antirollForce\": 6000\n    },\n    \"rear\": {\n      \"maxBrakeTorque\":
      5500,\n      \"antirollForce\": 5500\n    }\n  },\n  \"wheelFriction\": {\n   
      \"type\": \"Slippy\"\n  },\n  \"aerodynamics\": {\n    \"downForce\": 40,\n   
      \"airResistance\": 8,\n    \"wheelResistance\": 12\n  },\n  \"stability\":
      {\n    \"ABS\": true,\n    \"ESP\": true,\n    \"TCS\": true,\n    \"steerHelperStrength\":
      0.08,\n    \"tractionHelperStrength\": 0.06,\n    \"angularDragHelper\": true,\n   
      \"angularDragHelperStrength\": 0.1\n  },\n  \"vehicleBehavior\": \"Balanced\",\n 
      \"explanation\": \"Rally setup configured: Switched to AWD for better traction
      on mixed surfaces. Increased suspension travel to 0.35m (1.75x multiplier for
      rally compliance) with softer springs to absorb rough terrain. Lowered center
      of mass for stability. Increased torque to 320Nm and tuned gearbox with shorter
      ratios (4.5 first gear) and higher final drive (3.8) for quick acceleration
      out of corners. Added Slippy friction preset for loose surface grip. Increased
      downforce moderately (40) and added angular drag helper for better rotational
      stability. Limited slip ratio set to 70 (locked) for gravel traction. Maintained
      turbo and all stability aids for controllability on variable surfaces.\"\n}"
    beforeState: "Mass: 1600kg\r\nEngine: 300Nm, 700-7500RPM, 260km/h\r\n  Turbo:
      12psi\r\nClutch: engageRPM=1200, inertia=0.15, auto=True\r\nGearbox: Automatic,
      6 gears, shift=0.2s\r\n  Ratios: [4.35, 2.5, 1.66, 1.23, 1, 0.85]\r\n  ShiftRPM:
      up=6500, down=3750\r\nDiff (RCCP_Axle_Rear): Limited, slip=80, final=3.625914\r\nAxle
      (RCCP_Axle_Rear): steer=False, power=False, brake=True\r\n  steerAngle=40,
      brakeTorque=5000, antiroll=1000\r\nAxle (RCCP_Axle_Front): steer=True, power=False,
      brake=True\r\n  steerAngle=40, brakeTorque=5000, antiroll=1000\r\nStability:
      ABS=True, ESP=True, TCS=True\r\n  steerHelper=True (0.05), tractionHelper=True
      (0.05)\r\nSuspension: dist=0.2m, spring=65000, damper=4500\r\nAero: downForce=10\r\nNOS:
      enabled=True, multiplier=2.5, duration=3s\r\nFuel: enabled=True, capacity=60L\r\nInput:
      counterSteerFactor=1, counterSteering=True, steeringLimiter=True\r\n"
    beforeStateJson: "{\n    \"vehicleConfig\": {\n        \"name\": \"Model_Skyline
